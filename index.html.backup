<script>
/* Mobile menu */
const menuBtn = document.getElementById('menuBtn');
const mobileMenu = document.getElementById('mobileMenu');
menuBtn?.addEventListener('click', () => mobileMenu.classList.toggle('open'));
mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu.classList.remove('open')));

/* Reveal */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

/* Header on scroll */
const header = document.getElementById('siteHeader');
const onScroll = () => {
  if (window.scrollY > 8) header.classList.add('scrolled');
  else header.classList.remove('scrolled');
};
window.addEventListener('scroll', onScroll, {passive: true});
onScroll();

/* Currency converter */
const sendAmt = document.getElementById('sendAmt');
const recvAmt = document.getElementById('recvAmt');
const feeEl = document.getElementById('fee');
const gstEl = document.getElementById('gst');
const rateEl = document.getElementById('rate');
let baseRate = 83.42;

const fmt = (n, d=2) => n.toLocaleString('en-IN', {minimumFractionDigits:d, maximumFractionDigits:d});

function recalc(){
  const inr = +sendAmt.value || 0;
  const fee = inr * 0.0045;
  const gst = fee * 0.18;
  const usd = (inr - fee - gst) / baseRate;
  feeEl.textContent = fmt(fee, 0);
  gstEl.textContent = fmt(gst, 0);
  rateEl.textContent = baseRate.toFixed(2);
  recvAmt.style.opacity = 0.4;
  setTimeout(() => { recvAmt.textContent = fmt(usd); recvAmt.style.opacity = 1; }, 140);
}
sendAmt?.addEventListener('input', recalc);

/* Live rate tick */
setInterval(() => {
  baseRate = +(83.42 + (Math.random() - 0.5) * 0.18).toFixed(3);
  recalc();
  buildRates();
}, 3500);
recalc();

/* Live rates table */
const currencies = [
  { f:'🇺🇸', n:'US Dollar',         c:'USD', base:83.42 },
  { f:'🇪🇺', n:'Euro',              c:'EUR', base:90.18 },
  { f:'🇬🇧', n:'British Pound',     c:'GBP', base:105.74 },
  { f:'🇨🇦', n:'Canadian Dollar',   c:'CAD', base:60.92 },
  { f:'🇦🇺', n:'Australian Dollar', c:'AUD', base:54.31 },
  { f:'🇸🇬', n:'Singapore Dollar',  c:'SGD', base:61.85 },
  { f:'🇦🇪', n:'UAE Dirham',        c:'AED', base:22.71 },
  { f:'🇯🇵', n:'Japanese Yen',      c:'JPY', base:0.55 },
];

function buildRates(){
  const body = document.getElementById('ratesBody');
  if (!body) return;
  body.innerHTML = currencies.map(cur => {
    const wobble = (Math.random() - 0.5) * 0.4;
    const live = (cur.base + wobble).toFixed(2);
    const change = ((wobble / cur.base) * 100).toFixed(2);
    const up = +change >= 0;
    return `
      <div class="grid grid-cols-12 px-6 py-4 sm:py-5 items-center border-b border-ink-100 last:border-0 hover:bg-cream transition">
        <div class="col-span-7 sm:col-span-5 flex items-center gap-3">
          <span class="text-[18px]">${cur.f}</span>
          <div>
            <div class="text-[14.5px] font-medium text-ink-900">${cur.n}</div>
            <div class="text-[12px] text-ink-400 tabular">${cur.c} / INR</div>
          </div>
        </div>
        <div class="col-span-3 text-right tabular text-ink-900 text-[14.5px]">₹${live}</div>
        <div class="hidden sm:block col-span-2 text-right tabular text-[13px] ${up ? 'text-accent-600' : 'text-ink-500'}">${up ? '+' : ''}${change}%</div>
        <div class="col-span-2 text-right">
          <button class="text-[13px] font-medium text-ink-900 hover:text-accent-500 transition">Send →</button>
        </div>
      </div>`;
  }).join('');
}
buildRates();
</script>

</body>
</html>
