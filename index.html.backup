<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="description" content="Money2Abroad — Send money abroad at the real exchange rate. RBI authorised. Trusted by 4 million Indians worldwide." />
<meta name="theme-color" content="#FFFFFF" />
<title>Money2Abroad — International money transfers, beautifully simple.</title>

<link rel="icon" type="image/jpeg" href="Money2Abroad Logo.jpg" />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Inter+Tight:wght@400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      fontFamily: {
        sans:    ['Inter', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
        display: ['"Inter Tight"', 'Inter', 'system-ui', 'sans-serif'],
      },
      colors: {
        ink:    { DEFAULT:'#1D1D1F', 950:'#0A0A0A', 900:'#1D1D1F', 700:'#424245', 500:'#6E6E73', 400:'#86868B', 300:'#A1A1A6', 200:'#D2D2D7', 100:'#E5E5EA', 50:'#F5F5F7' },
        cream:  '#FBFBFD',
        accent: { 50:'#FFF4EA', 100:'#FFE4CC', 500:'#FF6A00', 600:'#E55A00' }
      },
      letterSpacing: {
        tightest: '-0.045em',
        tighter:  '-0.03em',
      },
      boxShadow: {
        card: '0 1px 2px rgba(0,0,0,0.04), 0 12px 40px -12px rgba(0,0,0,0.08)',
        cardHover: '0 1px 2px rgba(0,0,0,0.04), 0 24px 60px -20px rgba(0,0,0,0.12)',
      }
    }
  }
}
</script>

<style>
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    background: #FFFFFF;
    color: #1D1D1F;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }

  .font-display { font-family: 'Inter Tight', Inter, system-ui, sans-serif; font-feature-settings: 'ss01','cv11'; }

  /* Headline scaling */
  .h-display {
    font-size: clamp(40px, 7.5vw, 84px);
    line-height: 1.02;
    letter-spacing: -0.045em;
    font-weight: 600;
  }
  .h-section {
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    font-weight: 600;
  }
  .h-eyebrow {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #FF6A00;
  }
  .lede {
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.5;
    color: #424245;
    font-weight: 400;
  }

  /* Buttons — Apple-style pills */
  .btn-primary {
    background: #1D1D1F;
    color: #fff;
    border-radius: 980px;
    padding: 12px 22px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: background .2s ease, transform .2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-primary:hover { background: #000; }
  .btn-secondary {
    background: transparent;
    color: #1D1D1F;
    border: 1px solid #1D1D1F;
    border-radius: 980px;
    padding: 11px 22px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: background .2s ease, color .2s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-secondary:hover { background: #1D1D1F; color: #fff; }
  .btn-link {
    color: #1D1D1F;
    font-weight: 500;
    font-size: 15px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color .2s ease;
  }
  .btn-link:hover { color: #FF6A00; }
  .btn-link svg { transition: transform .2s ease; }
  .btn-link:hover svg { transform: translateX(2px); }

  /* Subtle reveal */
  .reveal { opacity: 0; transform: translateY(20px); transition: all 1s cubic-bezier(.16,.84,.44,1); }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* Live indicator */
  .live-dot { position: relative; }
  .live-dot::before {
    content: ""; position: absolute; inset: -3px; border-radius: 50%; background: #FF6A00; opacity: 0.35;
    animation: pulse 1.8s ease-out infinite;
  }
  @keyframes pulse { 0%{transform:scale(.7);opacity:.5} 100%{transform:scale(2.2);opacity:0} }

  /* FAQ */
  details summary { list-style: none; cursor: pointer; }
  details summary::-webkit-details-marker { display: none; }
  details[open] summary .faq-icon { transform: rotate(45deg); }
  .faq-icon { transition: transform .25s ease; }

  /* Mobile menu */
  #mobileMenu { transition: max-height .35s ease, opacity .25s ease; max-height: 0; overflow: hidden; opacity: 0; }
  #mobileMenu.open { max-height: 100vh; opacity: 1; }

  /* Refined hover lift */
  .lift { transition: transform .35s cubic-bezier(.16,.84,.44,1), box-shadow .35s ease; }
  .lift:hover { transform: translateY(-3px); }

  /* Compare row */
  .row-divider > * + * { border-top: 1px solid #E5E5EA; }

  /* Hide scrollbar */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { scrollbar-width: none; }

  /* Focus states */
  button:focus-visible, a:focus-visible, input:focus-visible {
    outline: 2px solid #FF6A00;
    outline-offset: 2px;
  }
  input { -webkit-appearance: none; appearance: none; }

  /* Hero glow */
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(255,106,0,0.06), transparent 50%),
                radial-gradient(circle at 10% 80%, rgba(29,29,31,0.04), transparent 40%);
    pointer-events: none;
  }

  /* Smooth currency flicker */
  .flicker { transition: opacity .3s ease; }

  /* Section spacing */
  .section { padding: clamp(64px, 10vw, 120px) 0; }

  /* Header scroll effect */
  #siteHeader.scrolled {
    background: rgba(255,255,255,0.85);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom-color: rgba(0,0,0,0.08);
  }

  /* Tabular numerals for financial data */
  .tabular { font-variant-numeric: tabular-nums; }
</style>
</head>
<body>

<!-- =========================== HEADER =========================== -->
<header id="siteHeader" class="sticky top-0 z-50 transition-all duration-300 border-b border-transparent">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8 h-14 sm:h-16 flex items-center justify-between">
    <a href="#" class="flex items-center" aria-label="Money2Abroad home">
      <img src="Money2Abroad Logo.jpg" alt="Money2Abroad" class="h-7 sm:h-8 w-auto" style="mix-blend-mode: multiply;" />
    </a>

    <nav class="hidden lg:flex items-center gap-9 text-[14px] font-normal text-ink-900">
      <a href="#send"      class="hover:opacity-60 transition">Send</a>
      <a href="#rates"     class="hover:opacity-60 transition">Rates</a>
      <a href="#purposes"  class="hover:opacity-60 transition">Use cases</a>
      <a href="#how"       class="hover:opacity-60 transition">How it works</a>
      <a href="#security"  class="hover:opacity-60 transition">Security</a>
      <a href="#faq"       class="hover:opacity-60 transition">Help</a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <button class="hidden sm:inline-flex text-[14px] font-normal text-ink-900 hover:opacity-60 transition">Sign in</button>
      <button class="btn-primary text-[14px]">Get started</button>
      <button id="menuBtn" class="lg:hidden p-2 -mr-2 text-ink-900" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 8h16M4 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
  <div id="mobileMenu" class="lg:hidden border-t border-ink-100 bg-white">
    <div class="px-5 py-5 flex flex-col gap-4 text-[16px] text-ink-900">
      <a href="#send">Send</a>
      <a href="#rates">Rates</a>
      <a href="#purposes">Use cases</a>
      <a href="#how">How it works</a>
      <a href="#security">Security</a>
      <a href="#faq">Help</a>
      <hr class="border-ink-100"/>
      <a href="#" class="text-ink-500">Sign in</a>
    </div>
  </div>
</header>

<!-- =========================== HERO =========================== -->
<section class="relative bg-cream overflow-hidden">
  <div class="hero-glow"></div>

  <div class="relative max-w-[1280px] mx-auto px-5 sm:px-8 pt-14 sm:pt-20 lg:pt-28 pb-16 sm:pb-24 lg:pb-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Headline -->
      <div class="lg:col-span-7 reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-ink-100 mb-7 sm:mb-9">
          <span class="live-dot w-1.5 h-1.5 bg-accent-500 rounded-full"></span>
          <span class="text-[12.5px] font-medium text-ink-700">RBI authorised · trusted by 4M+ Indians</span>
        </div>

        <h1 class="font-display h-display text-ink-900">
          Money to anywhere.<br/>
          <span class="text-ink-500">In a moment.</span>
        </h1>

        <p class="mt-6 sm:mt-8 lede max-w-xl">
          Send money abroad at the real exchange rate. No hidden fees, no surprises. Built for Indians sending money home, abroad, and everywhere in between.
        </p>

        <div class="mt-8 sm:mt-10 flex flex-wrap items-center gap-3">
          <button class="btn-primary">Send money <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
          <a href="#how" class="btn-link">How it works <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>

      <!-- Converter -->
      <div class="lg:col-span-5 reveal">
        <div class="bg-white rounded-2xl border border-ink-100 shadow-card overflow-hidden">
          <div class="px-6 pt-6 pb-2 flex items-center justify-between">
            <div class="text-[13px] font-medium text-ink-500">Live exchange</div>
            <div class="flex items-center gap-1.5 text-[12px] font-medium text-ink-500">
              <span class="live-dot w-1 h-1 bg-accent-500 rounded-full"></span>
              Real-time
            </div>
          </div>

          <div class="px-6 pt-2 pb-6 space-y-3">
            <!-- You send -->
            <label class="block">
              <div class="text-[12.5px] text-ink-500 mb-1.5">You send</div>
              <div class="flex items-stretch gap-2">
                <input id="sendAmt" type="number" inputmode="decimal" value="100000" class="flex-1 min-w-0 bg-cream rounded-xl px-4 py-3.5 text-[22px] sm:text-[24px] font-medium tracking-tighter tabular text-ink-900 outline-none focus:ring-2 focus:ring-ink-900" />
                <button class="flex items-center gap-2 px-4 py-3.5 bg-cream rounded-xl text-[14px] font-medium text-ink-900 whitespace-nowrap" aria-label="From INR">
                  <span class="text-base">🇮🇳</span> INR
                  <svg width="10" height="10" viewBox="0 0 12 12"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/></svg>
                </button>
              </div>
            </label>

            <!-- Fees breakdown -->
            <div class="px-1 py-1 space-y-1.5 text-[13.5px]">
              <div class="flex justify-between text-ink-500">
                <span>Our fee (0.45%)</span>
                <span class="tabular text-ink-900">− ₹<span id="fee">450</span></span>
              </div>
              <div class="flex justify-between text-ink-500">
                <span>GST (18% on fee)</span>
                <span class="tabular text-ink-900">− ₹<span id="gst">81</span></span>
              </div>
              <div class="flex justify-between text-ink-500 pt-1.5 border-t border-ink-100">
                <span>Mid-market rate</span>
                <span class="tabular text-ink-900">1 USD = ₹<span id="rate">83.42</span></span>
              </div>
            </div>

            <!-- Recipient gets -->
            <label class="block">
              <div class="text-[12.5px] text-ink-500 mb-1.5">Recipient gets</div>
              <div class="flex items-stretch gap-2">
                <div class="flicker flex-1 min-w-0 bg-ink-900 rounded-xl px-4 py-3.5 text-[22px] sm:text-[24px] font-medium tracking-tighter tabular text-white" id="recvAmt">1,191.49</div>
                <button class="flex items-center gap-2 px-4 py-3.5 bg-ink-900 text-white rounded-xl text-[14px] font-medium whitespace-nowrap" aria-label="To USD">
                  <span class="text-base">🇺🇸</span> USD
                  <svg width="10" height="10" viewBox="0 0 12 12"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/></svg>
                </button>
              </div>
            </label>

            <div class="flex items-center justify-between text-[12.5px] text-ink-500 pt-1">
              <span>Arrives in <span class="text-ink-900 font-medium">28 seconds</span></span>
              <span>Save <span class="text-accent-500 font-medium">₹3,920</span> vs banks</span>
            </div>

            <button class="btn-primary w-full justify-center mt-2 py-3.5 text-[15px]">Continue securely</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust strip -->
  <div class="border-t border-ink-100">
    <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-8 sm:py-10">
      <div class="text-[12px] uppercase tracking-[0.14em] text-ink-400 mb-5 sm:mb-6 font-medium">Authorised, audited, accredited</div>
      <div class="flex flex-wrap items-center gap-x-8 sm:gap-x-12 gap-y-4 text-[13.5px] font-medium text-ink-700">
        <div>RBI Authorised AD-II</div>
        <div class="hidden sm:block w-px h-4 bg-ink-200"></div>
        <div>FIU-IND Registered</div>
        <div class="hidden sm:block w-px h-4 bg-ink-200"></div>
        <div>ISO/IEC 27001</div>
        <div class="hidden sm:block w-px h-4 bg-ink-200"></div>
        <div>PCI-DSS Level 1</div>
        <div class="hidden sm:block w-px h-4 bg-ink-200"></div>
        <div>SOC 2 Type II</div>
      </div>
    </div>
  </div>
</section>

<!-- =========================== STAT NUMBERS =========================== -->
<section class="section bg-white">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 reveal">
      <div>
        <div class="font-display text-[44px] sm:text-[56px] tracking-tightest text-ink-900 leading-none tabular">₹47K Cr</div>
        <div class="mt-3 text-[14px] text-ink-500">Transferred annually across 180+ corridors</div>
      </div>
      <div>
        <div class="font-display text-[44px] sm:text-[56px] tracking-tightest text-ink-900 leading-none tabular">28<span class="text-ink-300">s</span></div>
        <div class="mt-3 text-[14px] text-ink-500">Median settlement time, end-to-end</div>
      </div>
      <div>
        <div class="font-display text-[44px] sm:text-[56px] tracking-tightest text-ink-900 leading-none tabular">4.2M<span class="text-ink-300">+</span></div>
        <div class="mt-3 text-[14px] text-ink-500">Indians worldwide transferring with us</div>
      </div>
      <div>
        <div class="font-display text-[44px] sm:text-[56px] tracking-tightest text-ink-900 leading-none tabular">99.99<span class="text-ink-300">%</span></div>
        <div class="mt-3 text-[14px] text-ink-500">Platform uptime — SLA-backed</div>
      </div>
    </div>
  </div>
</section>

<!-- =========================== LIVE RATES =========================== -->
<section id="rates" class="section bg-cream">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8">
    <div class="max-w-2xl mb-12 sm:mb-16 reveal">
      <div class="h-eyebrow mb-3">Live rates</div>
      <h2 class="font-display h-section text-ink-900">The mid-market rate. Always.</h2>
      <p class="mt-5 lede">No hidden FX margins, no quote inflation. The exact rate you'd see on Reuters — that's what you get.</p>
    </div>

    <div class="reveal bg-white rounded-2xl border border-ink-100 overflow-hidden">
      <div class="hidden sm:grid grid-cols-12 px-6 py-4 border-b border-ink-100 text-[12px] uppercase tracking-[0.08em] text-ink-400 font-medium">
        <div class="col-span-5">Currency</div>
        <div class="col-span-3 text-right">Live mid-market</div>
        <div class="col-span-2 text-right">24h</div>
        <div class="col-span-2 text-right">Action</div>
      </div>
      <div id="ratesBody"></div>
    </div>

    <div class="mt-5 text-[12.5px] text-ink-400 text-center sm:text-left">Refreshed every 3 seconds · Sourced from Reuters, Bloomberg, Refinitiv</div>
  </div>
</section>

<!-- =========================== FEATURE 1: SPEED =========================== -->
<section class="section bg-white">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-6 reveal order-2 lg:order-1">
        <div class="aspect-[4/3] rounded-2xl bg-cream border border-ink-100 p-8 sm:p-10 flex flex-col justify-between relative overflow-hidden">
          <div>
            <div class="text-[12px] uppercase tracking-[0.14em] text-ink-400 font-medium">Settlement timeline</div>
            <div class="mt-1 font-display text-[32px] sm:text-[40px] tracking-tighter text-ink-900">28 seconds</div>
          </div>
          <div class="space-y-3">
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-accent-500 shrink-0"></span><span class="text-[14px] text-ink-700">Mumbai → New York · 26s</span></div>
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-accent-500 shrink-0"></span><span class="text-[14px] text-ink-700">Bengaluru → London · 31s</span></div>
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-accent-500 shrink-0"></span><span class="text-[14px] text-ink-700">Delhi → Dubai · 18s</span></div>
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-accent-500 shrink-0"></span><span class="text-[14px] text-ink-700">Chennai → Singapore · 22s</span></div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-6 reveal order-1 lg:order-2">
        <div class="h-eyebrow mb-3">Speed</div>
        <h2 class="font-display h-section text-ink-900">Built on global rails.<br/>Tuned for Indian users.</h2>
        <p class="mt-6 lede max-w-lg">SWIFT gpi for traceability, RippleNet for liquidity, Visa Direct for last-mile reach. Three of the world's most trusted payment rails — orchestrated to deliver in seconds, not days.</p>
        <a href="#how" class="btn-link mt-8">See the architecture <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </div>
</section>

<!-- =========================== FEATURE 2: PRICE =========================== -->
<section class="section bg-cream">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-6 reveal">
        <div class="h-eyebrow mb-3">Price</div>
        <h2 class="font-display h-section text-ink-900">Up to 6× cheaper than your bank.</h2>
        <p class="mt-6 lede max-w-lg">A flat 0.45% fee. Mid-market exchange rate, always. Zero hidden margin. Compare it to your bank's transfer — the difference may surprise you.</p>
        <a href="#compare" class="btn-link mt-8">View comparison <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>

      <div class="lg:col-span-6 reveal">
        <div class="aspect-[4/3] rounded-2xl bg-white border border-ink-100 p-8 sm:p-10 flex flex-col justify-center">
          <div class="text-[12px] uppercase tracking-[0.14em] text-ink-400 font-medium mb-6">Sending ₹5,00,000 to USD</div>
          <div class="space-y-5">
            <div>
              <div class="flex justify-between text-[14px] mb-1.5"><span class="text-ink-500">Bank average</span><span class="tabular text-ink-900 font-medium">$5,832</span></div>
              <div class="h-1.5 bg-ink-100 rounded-full overflow-hidden"><div class="h-full bg-ink-300 rounded-full" style="width:97.5%"></div></div>
            </div>
            <div>
              <div class="flex justify-between text-[14px] mb-1.5"><span class="text-ink-500">Western Union</span><span class="tabular text-ink-900 font-medium">$5,775</span></div>
              <div class="h-1.5 bg-ink-100 rounded-full overflow-hidden"><div class="h-full bg-ink-300 rounded-full" style="width:96.5%"></div></div>
            </div>
            <div>
              <div class="flex justify-between text-[14px] mb-1.5"><span class="text-ink-900 font-medium">Money2Abroad</span><span class="tabular text-ink-900 font-semibold">$5,983</span></div>
              <div class="h-1.5 bg-ink-100 rounded-full overflow-hidden"><div class="h-full bg-accent-500 rounded-full" style="width:100%"></div></div>
            </div>
          </div>
          <div class="mt-7 pt-6 border-t border-ink-100 flex items-baseline justify-between">
            <span class="text-[13px] text-ink-500">Recipient gets more</span>
            <span class="font-display text-[28px] tracking-tighter text-ink-900">+ $151</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- =========================== HOW IT WORKS =========================== -->
<section id="how" class="section bg-white">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8">
    <div class="max-w-2xl mb-12 sm:mb-16 reveal">
      <div class="h-eyebrow mb-3">How it works</div>
      <h2 class="font-display h-section text-ink-900">Four steps. End-to-end.</h2>
    </div>

